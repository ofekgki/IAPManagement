# Copy to .env and adjust. Do NOT commit real secrets. Used by docker-compose.yml.

# Postgres
DATABASE_NAME=purchase_sdk
DATABASE_USER=purchase
DATABASE_PASSWORD=purchase
# Full JDBC URL the backend uses (compose builds this from the above by default).
DATABASE_URL=jdbc:postgresql://postgres:5432/purchase_sdk

# Backend security — generate strong random values for any real deployment.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
API_KEY_PEPPER=change-me-to-a-random-pepper
INTERNAL_ADMIN_TOKEN=change-me-internal-admin-token

# URLs
PORTAL_FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
